{
  "name": "autotube",
  "version": "1.0.0",
  "description": "AI-powered faceless YouTube channel automation platform",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "client": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "edge-tts-client": "^1.0.2",
    "express": "^4.22.1",
    "ffmpeg-static": "^5.3.0",
    "googleapis": "^171.4.0",
    "groq-sdk": "^0.37.0",
    "mongoose": "^8.23.0",
    "node-cron": "^3.0.3",
    "open": "^11.0.0",
    "youtube-search-api": "^2.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
