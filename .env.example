# Server
PORT=5000
NODE_ENV=development
SERVERLESS=false

# Database
MONGO_URI=mongodb://localhost:27017/youtube-ai

# AI - Required
GROQ_API_KEY=gsk_your_key_here

# Video Footage - Required
PEXELS_API_KEY=your_pexels_api_key

# YouTube OAuth2 - Optional (required for uploads)
YOUTUBE_API_KEY=your_youtube_api_key
YT_CLIENT_ID=your_client_id.apps.googleusercontent.com
YT_CLIENT_SECRET=GOCSPX-your_secret
YT_REDIRECT_URI=http://localhost:5000/api/youtube/callback

# Deployment (for production)
FRONTEND_URL=http://localhost:3000
